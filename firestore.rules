rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validAppointmentStatus(status) {
      return status in ["pending", "confirmed", "cancelled", "rejected"];
    }

    function isLimitedListQuery(maxLimit) {
      return request.query.limit != null && request.query.limit <= maxLimit;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == "patient";

      allow read: if isOwner(userId) || isAdmin();

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["fullName", "phone", "medicalProfile", "updatedAt"]);

      allow delete: if false;
    }

    match /doctors/{doctorId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow get: if signedIn()
        && (resource.data.patientId == request.auth.uid || isAdmin());

      allow list: if isAdmin()
        || (signedIn() && isLimitedListQuery(250));

      allow create: if signedIn()
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.status == "pending";

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.patientId == request.auth.uid
          && resource.data.status == "pending"
          && request.resource.data.patientId == resource.data.patientId
          && request.resource.data.patientEmail == resource.data.patientEmail
          && request.resource.data.patientName == resource.data.patientName
          && request.resource.data.patientPhone == resource.data.patientPhone
          && request.resource.data.createdAt == resource.data.createdAt
          && validAppointmentStatus(request.resource.data.status)
          && request.resource.data.status in ["pending", "cancelled"]
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              "doctorId",
              "doctorName",
              "department",
              "specialty",
              "date",
              "time",
              "symptoms",
              "status",
              "statusHistory",
              "updatedAt"
            ])
        );

      allow delete: if isAdmin()
        || (
          signedIn()
          && resource.data.patientId == request.auth.uid
          && resource.data.status == "cancelled"
        );
    }

    match /notifications/{notificationId} {
      allow get: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || (isAdmin() && resource.data.roleTarget == "admin")
        );

      allow list: if signedIn() && isLimitedListQuery(50);

      allow create: if signedIn()
        && (
          isAdmin()
          || (
            request.resource.data.roleTarget == "admin"
            && request.resource.data.userId == "admin"
          )
        );

      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"])
        && (
          resource.data.userId == request.auth.uid
          || (isAdmin() && resource.data.roleTarget == "admin")
        );

      allow delete: if false;
    }
  }
}
